# Copy this file to .env and fill in your values
# NEVER commit .env or .env.prod — they are in .gitignore
#
# For Flutter builds, use --dart-define-from-file=.env.prod
# to inject these at compile time via String.fromEnvironment().

# Supabase
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
